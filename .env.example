# Next.js Public Environment Variables (Appwrite Client)
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_ID=your_project_id
NEXT_PUBLIC_APPWRITE_DB=your_database_id

# Collection IDs
NEXT_PUBLIC_APPWRITE_PROJECT_COLLECTIONS=your_projects_collection_id
NEXT_PUBLIC_APPWRITE_MESSAGES_COLLECTIONS=your_messages_collection_id
NEXT_PUBLIC_APPWRITE_TESTIMONIAL_COLLECTIONS=your_testimonials_collection_id

# Storage Bucket IDs
NEXT_PUBLIC_APPWRITE_PROJECT_TESTI_PROFILE_BUCKET=your_profile_images_bucket_id
NEXT_PUBLIC_APPWRITE_PROJECT_RESUME_BUCKET=your_resume_bucket_id
NEXT_PUBLIC_APPWRITE_PROJECT_RESUME_FILE_ID=your_resume_file_id

# Note: Duplicate this file to .env.local and fill in your actual Appwrite credentials.
# Signups are typically disabled; ensure your Appwrite instance is configured for admin access.
